{
  "expo": {
    "name": "Bugsok AI",
    "slug": "Plant-Health-Tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/mascot-logo.jpeg",
    "scheme": "planthealthtracker",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/mascot-logo.jpeg"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/mascot-transparent.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.PlantHealthTracker"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/mascot-logo.jpeg"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ab29cdf4-376a-4926-b398-e3f500213a54"
      }
    }
  }
}
